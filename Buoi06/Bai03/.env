# sample environment variables
MONGODB_URI=mongodb://localhost:27017/fooddb
PORT=8080

# frontend can use REACT_APP_API_URL to call backend (e.g. http://localhost:8080)
REACT_APP_API_URL=

# Service URLs (when using docker-compose)
REACT_APP_USERS_URL=http://localhost:8081/api/users
REACT_APP_MENU_URL=http://localhost:8082/api/menu
REACT_APP_ORDERS_URL=http://localhost:8083/api/orders
